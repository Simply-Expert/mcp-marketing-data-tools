# Stripe
STRIPE_SECRET_KEY=sk_live_...

# App Store Connect
APPSTORE_ISSUER_ID=your-issuer-uuid
APPSTORE_KEY_ID=YOUR_KEY_ID
APPSTORE_PRIVATE_KEY_PATH=./keys/AuthKey_YOURKEYID.p8
APPSTORE_VENDOR_NUMBER=12345678
APPSTORE_APP_ID=1234567890

# Google Play Console
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./keys/service-account.json
GOOGLE_PLAY_PACKAGE_NAME=com.example.app
GOOGLE_PLAY_REPORTS_BUCKET=pubsite_prod_rev_...

# Google Search Console (uses same service account)
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://example.com

# Meta (Facebook + Instagram + Ads)
META_ACCESS_TOKEN=EAA...
META_PAGE_ID=123456789
META_INSTAGRAM_ACCOUNT_ID=17841...
META_AD_ACCOUNT_ID=act_123456

# Data directory (defaults to ./data)
DATA_DIR=./data
